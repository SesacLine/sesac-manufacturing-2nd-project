# kg_rca 산출물 (Neo4j 라이브 쿼리 대신 우선 hypotheses.json 사용)
# kg_rca는 SesacLine_SemiRCA 밑의 하위 폴더다 (0713부터 — 공동작업 편하게 이 repo 안으로 옮기고
# 자체 .git은 지웠다. 이 repo를 git init하면 안의 파일까지 그대로 하나의 히스토리로 잡힌다).
KG_HYPOTHESES_PATH=./kg_rca/outputs/hypotheses.json

# secsgem-mcp 서버 (MultiServerMCPClient stdio 연결용, README 예시 참고)
# secsgem-mcp도 마찬가지로 SesacLine_SemiRCA 밑의 하위 폴더다 (0713부터, 자체 .git 삭제됨).
MCP_SERVER_CWD=./secsgem-mcp
MCP_SERVER_PYTHONPATH=./secsgem-mcp
FAB_DB=./secsgem-mcp/datasets/fab.db

# app_state.db (fab.db와 별개 — 커서/배치 결과 저장용, 서비스가 매번 씀)
APP_STATE_DB=./app_state.db

# VLM / 응답생성 LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
